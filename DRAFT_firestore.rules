rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------------
    // 0. Default Deny
    // ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------
    // Helper Functions
    // ---------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == "desrieprathama@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---------------------------------------------------------------
    // Entity Validations
    // ---------------------------------------------------------------

    function isValidInvitation(data) {
      return data.keys().hasAll(['userId', 'slug', 'templateId', 'brideName', 'groomName', 'weddingDate', 'createdAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.slug is string && data.slug.size() <= 100 &&
             data.templateId in ['botanical', 'minimalist', 'rustic', 'midnight', 'sakura'] &&
             data.brideName is string && data.brideName.size() <= 100 &&
             data.groomName is string && data.groomName.size() <= 100 &&
             data.weddingDate is timestamp &&
             (data.get('musicUrl', '') is string && data.get('musicUrl', '').size() <= 500) &&
             data.createdAt is timestamp;
    }

    function isValidGuest(data) {
      return data.keys().hasAll(['name', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.status in ['Hadir', 'Tidak Hadir', 'Pending'] &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'message', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    function isValidMedia(data) {
      return data.keys().hasAll(['userId', 'url', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.url is string && data.url.size() <= 1000 &&
             data.type in ['image', 'audio'] &&
             data.createdAt is timestamp;
    }

    // ---------------------------------------------------------------
    // Resource Rules
    // ---------------------------------------------------------------

    match /invitations/{invitationId} {
      allow get: if isValidId(invitationId);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isValidId(invitationId) && isSignedIn() && incoming().userId == request.auth.uid && isValidInvitation(incoming()) && incoming().createdAt == request.time;
      allow update: if isValidId(invitationId) && isOwner(existing().userId) && isValidInvitation(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().slug == existing().slug
      );
      allow delete: if isValidId(invitationId) && (isOwner(existing().userId) || isAdmin());
    }

    match /media/{mediaId} {
      allow read: if isValidId(mediaId) && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isValidId(mediaId) && isSignedIn() && isValidMedia(incoming()) && incoming().createdAt == request.time;
      allow update: if isValidId(mediaId) && isOwner(existing().userId) && isValidMedia(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(mediaId) && (isOwner(existing().userId) || isAdmin());
    }

    match /guests/{guestId} {
      allow read: if isValidId(guestId) && isAdmin();
      allow create: if isValidId(guestId) && isValidGuest(incoming()) && incoming().createdAt == request.time;
      allow update, delete: if isValidId(guestId) && isAdmin();
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isValidId(messageId) && isValidMessage(incoming()) && incoming().createdAt == request.time;
      allow update, delete: if isValidId(messageId) && isAdmin();
    }

    match /consumers/{consumerId} {
      // Consumers are private.
      allow read: if isValidId(consumerId) && isAdmin();
      allow write: if isValidId(consumerId) && isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
